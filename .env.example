# BedJet Hub Configuration

# ---------------------------------------------------------
# Device Settings
# ---------------------------------------------------------
# BLE MAC address of the BedJet device.
# Leave empty to trigger auto-scan (if you only have one BedJet nearby).
# Example: BEDJET_ADDRESS=D4:8C:49:B7:11:F2
BEDJET_ADDRESS=

# ---------------------------------------------------------
# Hub API Settings
# ---------------------------------------------------------
# Network binding for the Hub REST API and WebSocket server
HUB_HOST=0.0.0.0
HUB_PORT=8265

# Path to the SQLite database (defaults to data/bedjet.db)
# DB_PATH=data/bedjet.db

# ---------------------------------------------------------
# Security Settings
# ---------------------------------------------------------
# CORS (Cross-Origin Resource Sharing) protects your Hub from being
# controlled by malicious scripts running on other websites you visit.
# 
# For security, you MUST explicitly list the URLs you use to access the web UI.
# Include the exact protocol, IP, and port.
#
# Examples:
# - If you access the UI at http://192.168.1.50:8678:
#   CORS_ORIGINS=http://localhost:8678,http://localhost:5173,http://192.168.1.50:8678
# - If using a custom domain:
#   CORS_ORIGINS=http://localhost:8678,http://bedjet.local:8678
# 
# DANGER: Using "*" allows any website to control your BedJet.
# CORS_ORIGINS=*

CORS_ORIGINS=http://localhost:8678,http://localhost:5173
